---
import Button from "./ui/Button.astro";
import SocialLinks from "./SocialLinks.astro";
import CustomDivider from "./vectorizing/CustomDivider.astro";
import CustomStyledDivider from "./vectorizing/CustomStyledDivider.astro";
---

<section
  id="inicio"
  aria-label="Presentación"
  class="flex flex-col md:flex-row md:justify-center md:gap-24 pt-10 md:pt-20"
>
  <!-- Text content: first on mobile, second on desktop -->
  <div class="flex flex-col gap-16 md:gap-32 px-6 md:px-0 order-1 md:order-2">
    <h1
      class="text-primary font-heading relative leading-tight
             text-5xl
             md:text-9xl md:max-w-3xl md:leading-36"
    >
      LA <br /> FRAGANCIA
      <span
        class="font-decorative text-secondary font-semibold absolute
               text-[60px] -bottom-10 right-0
               md:text-[145px] md:-bottom-20 md:-right-12"
      >
        JM
      </span>
    </h1>

    <div
      class="relative flex flex-col gap-8 md:gap-12 md:max-w-150 md:justify-center md:items-center"
    >
      <blockquote class="relative">
        <span
          class="font-quotation text-[60px] md:text-[84px] absolute -top-8 md:-top-10 left-0 text-secondary font-semibold"
          aria-hidden="true"
        >
          &ldquo;
        </span>

        <p
          class="font-testimonial ms-9 md:ms-11 block text-white text-lg md:text-2xl leading-8 md:leading-9 text-pretty"
        >
          La esencia del lujo, encapsulada en cada gota. Haz que cada paso tenga
          su propio aroma.
        </p>
      </blockquote>

      <section
        aria-label="Acciones principales"
        class="flex flex-row gap-3 justify-center md:gap-4 md:-ms-9"
      >
        <Button href="#coleccion" variant="action">
          Explora nuestra colección
        </Button>
        <Button href="#resenas" variant="secondary">
          Mira nuestras reseñas
        </Button>
      </section>

      <section
        aria-label="Redes sociales"
        class="md:-ms-9 flex justify-center md:mt-5"
      >
        <SocialLinks />
      </section>
    </div>
  </div>

  <!-- Decorative divider: mobile only, between text and image -->
  <div class="order-2 md:hidden w-full py-8">
    <CustomStyledDivider classes="w-full" />
  </div>

  <!-- Hero image: last on mobile, first (left) on desktop -->
  <div
    id="hero-image"
    class="relative w-full md:w-1/3 flex flex-col items-center justify-center gap-2.5 order-3 md:order-1"
  >
    <img
      src="/src/assets/hero-image.png"
      class="aspect-587/679 bg-blend-multiply object-cover w-full mask-linear-0 mask-linear-from-80% mask-linear-from-black mask-linear-to-transparent md:-mt-6"
      alt="Botella de perfume de La Fragancia JM"
    />

    <CustomStyledDivider
      classes="hidden md:block absolute -bottom-10 left-1/2 scale-150 transform -translate-x-1/2"
    />
  </div>
</section>

<script>
  const inicio = document.getElementById("inicio");
  const heroImage = document.getElementById("hero-image");

  if (inicio)
    inicio.addEventListener("mousemove", (event) => {
      if (heroImage) {
        const rect = inicio.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = (y - centerY) * 0.003;
        const rotateY = (x - centerX) * -0.003;

        heroImage.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
        heroImage.style.transition = "transform 0.1s ease-out";
      }
    });
</script>

