---
interface Props {
  href: string;
  variant?: "action" | "secondary";
}

const { href, variant = "action" } = Astro.props;

const baseClasses =
  "px-5 py-2 hover:cursor-pointer transition font-bold text-sm rounded-sm";

const variantClasses: Record<string, string> = {
  action: "bg-action text-black hover:bg-amber-500",
  secondary: "bg-secondary text-black hover:bg-black hover:text-white",
};
---

<a href={href} class:list={[baseClasses, variantClasses[variant]]}>
  <slot />
</a>
