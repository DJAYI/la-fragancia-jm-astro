---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "La Fragancia JM" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="La Fragancia JM — Perfumes de lujo. La esencia del lujo, encapsulada en cada gota."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    background-color: #000;

    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
